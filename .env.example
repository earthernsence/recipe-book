# Turso (https://turso.tech)
# Find these in your Turso dashboard after creating a database
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=

# Auth.js
# Generate with: bunx auth secret
AUTH_SECRET=

# GitHub OAuth App (https://github.com/settings/developers)
# Callback URL to register: https://your-vercel-domain.vercel.app/auth/callback/github
# For local dev, also add: http://localhost:5173/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Your GitHub numeric user ID — only this account can add/edit recipes
# Find yours at: https://api.github.com/users/your-username
ALLOWED_GITHUB_ID=